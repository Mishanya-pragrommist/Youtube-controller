{
    "manifest_version": 3,
    "name": "Youtube Controller",
    "description": "An extention which allows you to block some content and finally focus. Or just block Youtube entirely",
    "version": "1.0.0",
    
    "icons": {
        
    },
    "action": {
        "default_popup": "main.html"
    },
    "permissions": [
        "tabs",
        "notifications",
        "storage",
        "scripting"
    ],
    "background": {
        "service_worker": "js/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "js": ["js/content-wrapper.js"], 
            "matches": ["https://www.youtube.com/*"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "content-script.js", 
                "useful-stuff.js"
            ],
            "matches": ["https://www.youtube.com/*"]
        }
    ]
}